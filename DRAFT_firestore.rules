rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Specific Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt']) &&
             data.keys().size() == 4 && // Strict keys
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt == request.time;
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['title', 'game', 'price', 'description', 'sellerId', 'sellerName', 'status', 'level', 'rank', 'images', 'createdAt']) &&
             data.title is string && data.title.size() <= 100 &&
             data.game is string && data.game.size() <= 50 &&
             data.price is number && data.price > 0 &&
             data.sellerId == request.auth.uid &&
             data.status in ['available', 'sold', 'pending'] &&
             data.createdAt == (resource == null ? request.time : existing().createdAt) &&
             (resource == null || data.sellerId == existing().sellerId); // Immutable seller
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['buyerId', 'sellerId', 'accountId', 'amount', 'status', 'createdAt']) &&
             data.buyerId == request.auth.uid &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.createdAt == request.time;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Security: No blanket user listing
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );
    }

    match /accounts/{accountId} {
      allow get: if true;
      allow list: if true; // Public listings
      allow create: if isSignedIn() && isValidAccount(incoming());
      allow update: if isSignedIn() && (
        // Action: Seller Edit
        (isOwner(existing().sellerId) && isValidAccount(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'images', 'level', 'rank'])) ||
        // Action: Status Update (during order)
        (incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status in ['pending', 'sold'])
      );
      allow delete: if isSignedIn() && isOwner(existing().sellerId) && existing().status == 'available';
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().buyerId) || isOwner(existing().sellerId));
      allow list: if isSignedIn(); // Each user sees their own via resource check
      allow create: if isSignedIn() && isValidOrder(incoming()) &&
                      get(/databases/$(database)/documents/accounts/$(incoming().accountId)).data.status == 'available';
      allow update: if isSignedIn() && (
        (isOwner(existing().buyerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'cancelled') ||
        (isOwner(existing().sellerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'completed')
      );
    }
  }
}
